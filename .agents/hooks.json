{
  "code-formatting-pipeline": {
    "PostToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/hooks/format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
